# OpenAPI Spec Source
# Supports: Swagger UI URL, direct /v3/api-docs endpoint, or /api-docs.json
SWAGGER_URL=https://api.example.com/swagger-ui/index.html

# Authentication (optional)
# Options: bearer, basic, api-key

# Bearer token auth
SWAGGER_AUTH_TYPE=bearer
SWAGGER_AUTH_TOKEN=your-jwt-token

# Basic auth (uncomment to use)
# SWAGGER_AUTH_TYPE=basic
# SWAGGER_AUTH_USERNAME=admin
# SWAGGER_AUTH_PASSWORD=secret

# API key auth (uncomment to use)
# SWAGGER_AUTH_TYPE=api-key
# SWAGGER_API_KEY_NAME=X-API-Key
# SWAGGER_API_KEY_VALUE=your-api-key

# Fetch options
SWAGGER_FETCH_TIMEOUT=30000
