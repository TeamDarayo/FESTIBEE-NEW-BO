{
  "name": "festibee-new-bo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "ui:add": "pnpm --filter @festibee/ui add",
    "ui:diff": "pnpm --filter @festibee/ui diff",
    "storybook": "turbo run storybook --filter=@festibee/storybook"
  },
  "devDependencies": {
    "turbo": "^2.7.0",
    "typescript": "5.9.2",
    "prettier": "^3.4.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
